<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Submissions — OD Anvaya</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .sub-shell { display: flex; min-height: 100vh; }
    .sub-sidebar {
      width: 20%; min-width: 220px; max-width: 300px;
      background: var(--bg-sidebar); border-right: 1px solid var(--bg-card);
      display: flex; flex-direction: column; padding: 20px 0;
      flex-shrink: 0; position: sticky; top: 0; height: 100vh; overflow-y: auto;
    }
    .sub-main { flex: 1; overflow-y: auto; padding: 32px 48px; min-width: 0; }
    .org-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: var(--radius-lg); padding: 28px 32px; margin-bottom: 20px;
      transition: border-color 0.2s;
    }
    .org-card:hover { border-color: var(--border-accent); }
    .org-card.expanded { border-color: var(--accent); }
    .cap-row {
      display: grid; grid-template-columns: 28px 1fr 50px 120px;
      gap: 12px; align-items: center; padding: 8px 0;
      border-bottom: 1px solid rgba(30,45,69,0.3);
    }
    .cap-row:last-child { border-bottom: none; }
    .mini-bar { height: 6px; border-radius: 3px; background: var(--border); overflow: hidden; }
    .mini-bar-fill { height: 100%; border-radius: 3px; transition: width 0.3s; }
    .status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
    .org-nav-item {
      display: block; padding: 10px 16px; cursor: pointer;
      border-left: 3px solid transparent; transition: all 0.15s;
      text-decoration: none;
    }
    .org-nav-item:hover { background: rgba(13,27,46,0.5); text-decoration: none; }
    .org-nav-item.active { border-left-color: var(--accent); background: var(--bg-card); }
    .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 1200px) { .detail-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
<%
  const levelColors = { 1: '#ef4444', 2: '#f97316', 3: '#eab308', 4: '#22c55e' };
  const levelNames = { 1: 'Nascent', 2: 'Emerging', 3: 'Developing', 4: 'Advanced' };
  const priorityIcons = { Critical: '🔴', High: '🟠', Medium: '🔵', Low: '⚪' };
  const selectedOrg = typeof activeOrgId !== 'undefined' ? activeOrgId : null;
%>
<div class="sub-shell">
  <!-- Sidebar -->
  <div class="sub-sidebar">
    <div style="padding:0 16px 16px;border-bottom:1px solid var(--bg-card);margin-bottom:10px">
      <div class="mono" style="font-size:0.6rem;letter-spacing:0.2em;color:var(--accent);margin-bottom:4px">APD · OD TOOL</div>
      <div style="font-size:1.07rem;font-weight:800;color:var(--text-primary)">Submissions</div>
    </div>

    <div style="padding:0 16px 12px;border-bottom:1px solid var(--bg-card);margin-bottom:8px">
      <div class="flex justify-between" style="font-family:var(--font-mono);font-size:0.67rem;color:var(--text-dim);margin-bottom:6px">
        <span>NGOs</span><span style="color:var(--accent)"><%= stats.totalNGOs %></span>
      </div>
      <div class="flex gap-12" style="font-size:0.67rem;font-family:var(--font-mono)">
        <span style="color:var(--level-4)"><%= stats.completedAssessments %> done</span>
        <span style="color:var(--accent-blue)"><%= stats.inProgress %> active</span>
        <span style="color:var(--text-dim)"><%= stats.notStarted %> pending</span>
      </div>
    </div>

    <a href="/admin" class="org-nav-item" style="margin-bottom:4px">
      <div class="mono" style="font-size:0.67rem;color:var(--text-dim);letter-spacing:0.1em">ADMIN</div>
      <div style="font-size:0.8rem;color:var(--text-muted);font-weight:600">Dashboard</div>
    </a>
    <a href="/admin/submissions" class="org-nav-item active">
      <div class="mono" style="font-size:0.67rem;color:var(--accent);letter-spacing:0.1em">VIEW</div>
      <div style="font-size:0.8rem;color:var(--text-primary);font-weight:600">All Submissions</div>
    </a>

    <div style="padding:12px 16px 8px;border-top:1px solid var(--bg-card);margin-top:8px">
      <div class="mono" style="font-size:0.6rem;color:var(--text-dim);letter-spacing:0.1em;margin-bottom:8px">ORGANISATIONS</div>
    </div>

    <% for (const org of orgs) {
      const rated = parseInt(org.rated_count) || 0;
      const pct = totalSubs > 0 ? Math.round(rated / totalSubs * 100) : 0;
      const avg = org.avg_score ? parseFloat(org.avg_score) : null;
      const avgColor = avg ? levelColors[Math.round(avg)] : 'var(--text-dim)';
    %>
    <a href="#org-<%= org.user_id %>" class="org-nav-item" onclick="scrollToOrg(<%= org.user_id %>)">
      <div class="flex justify-between items-center">
        <div style="font-size:0.8rem;color:var(--text-secondary);font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px"><%= org.org_name %></div>
        <% if (avg) { %>
        <span class="mono" style="font-size:0.8rem;font-weight:800;color:<%= avgColor %>"><%= avg.toFixed(1) %></span>
        <% } %>
      </div>
      <div class="flex items-center gap-8" style="margin-top:4px">
        <div class="mini-bar flex-1">
          <div class="mini-bar-fill" style="width:<%= pct %>%;background:<%= avgColor %>"></div>
        </div>
        <span class="mono" style="font-size:0.6rem;color:var(--text-dim)"><%= pct %>%</span>
      </div>
    </a>
    <% } %>

    <div style="margin-top:auto;padding:12px 16px;border-top:1px solid var(--bg-card)">
      <a href="/logout" class="btn btn-ghost btn-sm w-full" style="justify-content:center">LOG OUT</a>
    </div>
  </div>

  <!-- Main content -->
  <div class="sub-main">
    <!-- Platform KPIs -->
    <div class="flex justify-between items-start mb-28 flex-wrap gap-16">
      <div>
        <div class="mono text-muted" style="font-size:0.73rem;letter-spacing:0.12em;margin-bottom:6px">PARTNER NGO SUBMISSIONS</div>
        <h1 style="margin-bottom:4px">Assessment Overview</h1>
        <div class="mono text-muted" style="font-size:0.8rem"><%= orgs.length %> organisations · <%= totalSubs %> sub-capabilities per assessment</div>
      </div>
      <div class="flex gap-10">
        <a href="/admin" class="btn btn-ghost btn-sm">Dashboard</a>
        <button onclick="window.print()" class="btn btn-ghost btn-sm">Print</button>
      </div>
    </div>

    <div class="grid grid-4 gap-14 mb-32">
      <div class="stat-card">
        <div class="stat-num" style="color:var(--accent)"><%= stats.totalNGOs %></div>
        <div class="stat-label">PARTNER NGOS</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" style="color:var(--level-4)"><%= stats.completedAssessments %></div>
        <div class="stat-label">FULLY ASSESSED</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" style="color:<%= stats.platformAvg ? levelColors[Math.round(stats.platformAvg)] : 'var(--text-dim)' %>"><%= stats.platformAvg ? stats.platformAvg.toFixed(1) : '—' %></div>
        <div class="stat-label">PLATFORM AVERAGE</div>
      </div>
      <div class="stat-card">
        <div class="stat-num" style="color:var(--accent-blue)"><%= stats.inProgress %></div>
        <div class="stat-label">IN PROGRESS</div>
      </div>
    </div>

    <!-- Organisation Cards -->
    <% for (const org of orgs) {
      const rated = parseInt(org.rated_count) || 0;
      const targets = parseInt(org.target_count) || 0;
      const priorities = parseInt(org.priority_count) || 0;
      const criticals = parseInt(org.critical_count) || 0;
      const timelines = parseInt(org.timeline_count) || 0;
      const pct = totalSubs > 0 ? Math.round(rated / totalSubs * 100) : 0;
      const avg = org.avg_score ? parseFloat(org.avg_score) : null;
      const avgColor = avg ? levelColors[Math.round(avg)] : 'var(--text-dim)';
      const minScore = org.min_score ? parseInt(org.min_score) : null;
      const maxScore = org.max_score ? parseInt(org.max_score) : null;

      // Level distribution
      const dist = { 1: 0, 2: 0, 3: 0, 4: 0 };
      if (org.capScores) {
        // We approximate from cap averages — not exact but good for overview
      }
    %>
    <div class="org-card" id="org-<%= org.user_id %>">
      <!-- Org Header -->
      <div class="flex justify-between items-start mb-20 gap-16 flex-wrap">
        <div style="flex:1;min-width:200px">
          <div class="flex items-center gap-12 mb-6">
            <h2 style="font-size:1.33rem"><%= org.org_name %></h2>
            <% if (pct === 100) { %>
            <span class="tag tag-accent">COMPLETE</span>
            <% } else if (rated > 0) { %>
            <span class="tag" style="background:rgba(14,165,233,0.1);border:1px solid rgba(14,165,233,0.25);color:var(--accent-blue)">IN PROGRESS</span>
            <% } else { %>
            <span class="tag" style="background:rgba(100,116,139,0.1);border:1px solid rgba(100,116,139,0.25);color:var(--text-muted)">NOT STARTED</span>
            <% } %>
          </div>
          <div class="flex gap-16 flex-wrap" style="font-size:0.8rem;color:var(--text-muted)">
            <span><%= org.user_name %> &middot; <%= org.email %></span>
            <% if (org.assessor) { %><span>Assessor: <span style="color:var(--text-secondary)"><%= org.assessor %></span></span><% } %>
            <% if (org.assessment_date) { %><span><%= new Date(org.assessment_date).toLocaleDateString('en-IN', {day:'numeric',month:'short',year:'numeric'}) %></span><% } %>
          </div>
          <% if (org.context_notes) { %>
          <div style="font-size:0.8rem;color:var(--text-dim);margin-top:6px;line-height:1.6"><%= org.context_notes.substring(0, 200) %><%= org.context_notes.length > 200 ? '...' : '' %></div>
          <% } %>
        </div>
        <div class="flex gap-12">
          <% if (avg) { %>
          <div class="stat-card" style="padding:14px 18px;min-width:80px;text-align:center">
            <div class="mono" style="font-size:1.6rem;font-weight:800;color:<%= avgColor %>"><%= avg.toFixed(1) %></div>
            <div class="mono text-dim" style="font-size:0.6rem;letter-spacing:0.1em">AVERAGE</div>
          </div>
          <% } %>
          <div class="stat-card" style="padding:14px 18px;min-width:80px;text-align:center">
            <div class="mono" style="font-size:1.6rem;font-weight:800;color:<%= pct === 100 ? 'var(--level-4)' : 'var(--accent-blue)' %>"><%= pct %>%</div>
            <div class="mono text-dim" style="font-size:0.6rem;letter-spacing:0.1em">COMPLETE</div>
          </div>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="mb-20">
        <div class="flex justify-between mb-4" style="font-family:var(--font-mono);font-size:0.67rem;color:var(--text-dim)">
          <span><%= rated %>/<%= totalSubs %> sub-capabilities rated</span>
          <div class="flex gap-12">
            <span><%= targets %> targets</span>
            <span><%= priorities %> prioritised</span>
            <span><%= timelines %> timelines</span>
            <span><%= org.milestoneCount %> milestones</span>
          </div>
        </div>
        <div class="progress-bar" style="height:6px">
          <div class="progress-bar-fill" style="width:<%= pct %>%;background:<%= avgColor %>"></div>
        </div>
      </div>

      <% if (rated > 0) { %>
      <!-- Quick stats row -->
      <div class="flex gap-16 mb-20 flex-wrap" style="font-size:0.73rem;font-family:var(--font-mono)">
        <% if (criticals > 0) { %><span style="color:var(--level-1)">🔴 <%= criticals %> critical</span><% } %>
        <% if (minScore) { %><span style="color:<%= levelColors[minScore] %>">Min: L<%= minScore %></span><% } %>
        <% if (maxScore) { %><span style="color:<%= levelColors[maxScore] %>">Max: L<%= maxScore %></span><% } %>
        <% if (org.last_activity) { %><span style="color:var(--text-dim)">Last active: <%= new Date(org.last_activity).toLocaleDateString('en-IN', {day:'numeric',month:'short'}) %></span><% } %>
      </div>

      <!-- Capability scores breakdown -->
      <div class="detail-grid">
        <div>
          <div class="mono text-dim" style="font-size:0.67rem;letter-spacing:0.1em;margin-bottom:12px">CAPABILITY SCORES</div>
          <% for (const cs of org.capScores) {
            const csAvg = cs.avg ? parseFloat(cs.avg) : null;
            const csColor = csAvg ? levelColors[Math.round(csAvg)] : 'var(--text-dim)';
          %>
          <div class="cap-row">
            <span><%= cs.icon %></span>
            <div style="font-size:0.73rem;color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= cs.name %></div>
            <div class="mono" style="font-size:0.73rem;font-weight:700;color:<%= csColor %>;text-align:right"><%= csAvg ? csAvg.toFixed(1) : '—' %></div>
            <div class="mini-bar">
              <div class="mini-bar-fill" style="width:<%= csAvg ? (csAvg/4*100) : 0 %>%;background:<%= csColor %>"></div>
            </div>
          </div>
          <% } %>
        </div>
        <div>
          <div class="mono text-dim" style="font-size:0.67rem;letter-spacing:0.1em;margin-bottom:12px">LEVEL DISTRIBUTION</div>
          <% if (org.capScores.length > 0) {
            const lvlCounts = { 1: 0, 2: 0, 3: 0, 4: 0 };
            for (const cs of org.capScores) {
              if (cs.avg) {
                const r = Math.round(parseFloat(cs.avg));
                lvlCounts[r] = (lvlCounts[r] || 0) + parseInt(cs.rated);
              }
            }
          %>
          <div style="padding:16px 20px;background:var(--bg-input);border-radius:var(--radius-md);border:1px solid var(--border)">
            <% for (let l = 4; l >= 1; l--) { %>
            <div class="flex items-center gap-12 mb-8">
              <span class="level-badge level-badge-<%= l %> level-badge-sm" style="min-width:70px;text-align:center">L<%= l %></span>
              <div class="mini-bar flex-1" style="height:8px">
                <div class="mini-bar-fill" style="width:<%= rated > 0 ? (lvlCounts[l]/rated*100) : 0 %>%;background:<%= levelColors[l] %>"></div>
              </div>
              <span class="mono" style="font-size:0.67rem;color:var(--text-dim);min-width:20px;text-align:right"><%= lvlCounts[l] %></span>
            </div>
            <% } %>
          </div>
          <% } %>

          <div style="margin-top:16px">
            <a href="/report/<%= org.user_id %>" class="btn btn-primary btn-sm w-full" style="justify-content:center">VIEW FULL REPORT &rarr;</a>
          </div>
        </div>
      </div>
      <% } else { %>
      <div class="text-center" style="padding:24px;border:1.5px dashed var(--border);border-radius:var(--radius-md);color:var(--text-dim);font-size:0.87rem">
        Assessment not started yet
      </div>
      <% } %>
    </div>
    <% } %>

    <% if (orgs.length === 0) { %>
    <div class="card text-center" style="border-style:dashed;padding:48px">
      <div style="font-size:2rem;margin-bottom:12px">📋</div>
      <div class="text-dim" style="font-size:1rem">No submissions yet. Partner NGOs will appear here once they register.</div>
    </div>
    <% } %>
  </div>
</div>

<script>
function scrollToOrg(userId) {
  const el = document.getElementById('org-' + userId);
  if (el) {
    el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    el.classList.add('expanded');
    setTimeout(() => el.classList.remove('expanded'), 2000);
  }
}
</script>
</body>
</html>
