<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — OD Anvaya</title>
  <link rel="stylesheet" href="/css/style.css">
  <script type="module">import*as T from'https://cdn.jsdelivr.net/npm/@hotwired/turbo/dist/turbo.es2017-esm.js';window.Turbo=T;</script>
</head>
<body>
<div class="auth-shell">
  <div class="auth-brand">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div style="position:relative;text-align:center;max-width:380px">
      <div style="width:64px;height:64px;border-radius:50%;background:var(--gradient);display:flex;align-items:center;justify-content:center;font-size:1.87rem;margin:0 auto 24px">♿</div>
      <div class="mono" style="font-size:0.75rem;color:var(--accent);letter-spacing:0.2em;margin-bottom:12px">ASSOCIATION OF PEOPLE WITH DISABILITY</div>
      <h1 style="margin-bottom:16px">Partner NGO<br><span class="gradient-text">OD Assessment Tool</span></h1>
      <p style="color:var(--text-dim);font-size:0.87rem;line-height:1.8">A structured platform for APD's partner organisations to assess capabilities, identify gaps, and build inclusive development plans.</p>
      <div style="margin-top:36px;display:flex;flex-direction:column;gap:10px">
        <% const features = ['13 Organisational Capabilities', '4-Level Maturity Scale', 'Milestone-Based Action Planning', 'DEI Integration', 'Gantt Timeline & Reports']; %>
        <% for (const f of features) { %>
        <div class="flex items-center gap-10" style="font-size:0.8rem;color:var(--text-dim)">
          <div style="width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0"></div><%= f %>
        </div>
        <% } %>
      </div>
    </div>
  </div>
  <div class="auth-form-panel">
    <div class="auth-title">Welcome back</div>
    <div class="auth-subtitle">Sign in to continue your OD assessment.</div>
    <% if (error) { %><div class="auth-error"><%= error %></div><% } %>
    <form method="POST" action="/login" style="display:flex;flex-direction:column;gap:16px">
      <div class="form-group">
        <label class="form-label">EMAIL ADDRESS</label>
        <input type="email" name="email" class="form-input" placeholder="you@ngo.org" required>
      </div>
      <div class="form-group">
        <label class="form-label">PASSWORD</label>
        <div class="input-eye-wrap">
          <input type="password" name="password" class="form-input" placeholder="••••••••" required>
          <button type="button" class="eye-toggle" onclick="togglePw(this)" aria-label="Show password">
            <svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8S1 12 1 12z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg class="eye-shut" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
          </button>
        </div>
      </div>
      <button type="submit" class="btn btn-gradient btn-lg w-full" style="justify-content:center">SIGN IN →</button>
    </form>
    <div class="auth-switch">
      New to the platform? <a href="/register" style="font-weight:700">Create an account</a>
    </div>
    <div class="auth-admin-hint">
      <div class="mono" style="font-size:0.7rem;color:var(--text-ghost);letter-spacing:0.12em;margin-bottom:6px">APD ADMIN ACCESS</div>
      <div style="font-size:0.8rem;color:var(--text-ghost)">admin@apd.org · contact APD for credentials</div>
    </div>
  </div>
</div>
<script>
function togglePw(btn){
  const inp=btn.parentElement.querySelector('input');
  const show=inp.type==='password';
  inp.type=show?'text':'password';
  btn.querySelector('.eye-open').style.display=show?'none':'';
  btn.querySelector('.eye-shut').style.display=show?'':'none';
}
</script>
</body>
</html>
