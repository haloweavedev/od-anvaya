<%
  // Usage: include('partials/level-badge', { level: 3, size: 'sm' })
  const lvl = typeof level !== 'undefined' ? level : null;
  const sz = typeof size !== 'undefined' && size === 'sm' ? 'level-badge-sm' : '';
  const names = { 1: 'Nascent', 2: 'Emerging', 3: 'Developing', 4: 'Advanced' };
%>
<% if (lvl) { %>
<span class="level-badge level-badge-<%= lvl %> <%= sz %>">L<%= lvl %> · <%= names[lvl] %></span>
<% } else { %>
<span style="color:var(--text-dim);font-size:0.8rem;font-family:var(--font-mono)">—</span>
<% } %>
