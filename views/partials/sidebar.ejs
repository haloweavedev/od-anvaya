<%
  const navItems = [
    { id: 'setup', href: '/setup', step: '01', label: 'Setup', icon: '⚙️' },
    { id: 'assess', href: '/assess', step: '02', label: 'Assess', icon: '🎯' },
    { id: 'plan', href: '/plan', step: '03', label: 'Plan', icon: '📋' },
    { id: 'report', href: '/report', step: '04', label: 'Report', icon: '📊' },
  ];
  const currentPage = typeof page !== 'undefined' ? page : '';
  const totalSubs = typeof totalSubCount !== 'undefined' ? totalSubCount : 46;
  const ratedCount = typeof ratedSubCount !== 'undefined' ? ratedSubCount : 0;
  const pct = totalSubs > 0 ? Math.round((ratedCount / totalSubs) * 100) : 0;
  const sidebarCaps = typeof capList !== 'undefined' ? capList : null;
  const sidebarActiveCap = typeof activeCapIndex !== 'undefined' ? activeCapIndex : 0;
%>
<div class="sidebar">
  <div class="sidebar-logo">
    <div class="brand">APD · OD TOOL</div>
    <div class="title">Partner NGO<br>OD Planner</div>
  </div>

  <% if (user && user.org_name) { %>
  <div class="sidebar-org">
    <div class="label">CURRENT NGO</div>
    <div class="name"><%= user.org_name %></div>
  </div>
  <% } %>

  <% if (user && user.is_admin) { %>
  <a href="/admin" class="nav-item <%= currentPage === 'admin' ? 'active' : '' %>">
    <div class="flex items-center gap-8">
      <span class="nav-icon">🛡️</span>
      <div>
        <div class="step">ADMIN</div>
        <div class="label">Dashboard</div>
      </div>
    </div>
  </a>
  <a href="/admin/submissions" class="nav-item <%= currentPage === 'submissions' ? 'active' : '' %>">
    <div class="flex items-center gap-8">
      <span class="nav-icon">📬</span>
      <div>
        <div class="step">ADMIN</div>
        <div class="label">Submissions</div>
      </div>
    </div>
  </a>
  <div style="border-bottom:1px solid var(--bg-card);margin:6px 0"></div>
  <% } %>

  <% for (const nav of navItems) { %>
  <a href="<%= nav.href %>" class="nav-item <%= currentPage === nav.id ? 'active' : '' %>">
    <div class="flex items-center gap-8">
      <span class="nav-icon"><%= nav.icon %></span>
      <div>
        <div class="step"><%= nav.step %></div>
        <div class="label"><%= nav.label %></div>
      </div>
    </div>
  </a>
  <% } %>

  <% if (sidebarCaps && sidebarCaps.length > 0) { %>
  <div class="sidebar-caps">
    <div class="caps-label">CAPABILITIES</div>
    <% sidebarCaps.forEach((c, i) => {
      const isActive = i === sidebarActiveCap;
    %>
    <a href="?cap=<%= i %>" class="cap-card <%= isActive ? 'active' : '' %>" style="<%= isActive ? 'border-color:'+c.color+'88' : '' %>">
      <div class="flex items-center gap-6 mb-4">
        <span class="cap-icon"><%= c.icon %></span>
        <div class="cap-name"><%= c.name %></div>
      </div>
      <% if (c.stat) { %>
      <div class="cap-stat"><%= c.stat %></div>
      <% } %>
    </a>
    <% }); %>
  </div>
  <% } %>

  <div class="sidebar-footer">
    <% if (user) { %>
    <div class="user-row">
      <div class="user-info">
        <div class="user-org"><%= user.org_name %></div>
        <div class="user-email"><%= user.email %></div>
      </div>
      <% const circ = 2 * Math.PI * 5.5; const dash = circ - (pct / 100) * circ; %>
      <div class="progress-badge">
        <svg class="progress-ring" viewBox="0 0 14 14">
          <circle class="ring-bg" cx="7" cy="7" r="5.5"/>
          <circle class="ring-fill" cx="7" cy="7" r="5.5" stroke-dasharray="<%= circ %>" stroke-dashoffset="<%= dash %>"/>
        </svg>
        <%= pct %>%
        <div class="progress-tooltip">
          <div style="font-size:0.7rem;color:var(--text-dim);letter-spacing:0.1em;margin-bottom:6px">PROGRESS</div>
          <div style="font-size:0.8rem;color:var(--accent);font-weight:700;margin-bottom:6px"><%= ratedCount %> / <%= totalSubs %> rated</div>
          <div class="progress-bar" style="height:4px">
            <div class="progress-bar-fill" style="width:<%= pct %>%"></div>
          </div>
        </div>
      </div>
      <a href="/logout" class="btn btn-ghost btn-sm" style="padding:4px 8px;font-size:0.7rem">OUT</a>
    </div>
    <% } %>
  </div>
</div>
