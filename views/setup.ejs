<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Setup — OD Anvaya</title>
  <link rel="stylesheet" href="/css/style.css">
  <script type="module">import*as T from'https://cdn.jsdelivr.net/npm/@hotwired/turbo/dist/turbo.es2017-esm.js';window.Turbo=T;</script>
</head>
<body>
<%
  const totalSubCount = 46;
  const ratedSubCount = 0;
%>
<div class="app-shell">
  <%- include('partials/sidebar', { page: 'setup', totalSubCount, ratedSubCount, capList: null, activeCapIndex: 0 }) %>
  <div class="main-content">
    <div style="width:100%">

      <!-- Welcome banner -->
      <div class="card mb-28" style="border-color:var(--accent)33;background:linear-gradient(135deg, rgba(99,202,183,0.06), rgba(14,165,233,0.04))">
        <div class="flex gap-16 items-start">
          <div style="width:48px;height:48px;border-radius:50%;background:var(--gradient);display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0">♿</div>
          <div>
            <h1 style="font-size:1.6rem;margin-bottom:6px">Partner NGO <span class="text-accent">OD Assessment</span></h1>
            <p style="color:var(--text-muted);font-size:0.93rem;line-height:1.7;margin-bottom:0">
              A structured tool by APD to assess organisational strengths across 13 capability areas, identify gaps, and co-create a prioritised development plan. Set aside 60–90 minutes with your leadership team.
            </p>
          </div>
        </div>
      </div>

      <form method="POST" action="/setup">
        <!-- Organisation details -->
        <div class="card mb-24">
          <h2 class="mono" style="font-size:1.07rem;letter-spacing:0.08em;margin-bottom:24px;color:var(--text-secondary)">ORGANISATION DETAILS</h2>
          <div class="grid grid-2 gap-20 mb-20">
            <div class="form-group">
              <label class="form-label">ORGANISATION NAME</label>
              <input type="text" name="orgName" class="form-input" value="<%= assessment.org_name || '' %>" placeholder="e.g. Praja Foundation" required>
            </div>
            <div class="form-group">
              <label class="form-label">LEAD ASSESSOR</label>
              <input type="text" name="assessor" class="form-input" value="<%= assessment.assessor || '' %>" placeholder="e.g. Anita Sharma">
            </div>
            <div class="form-group">
              <label class="form-label">ASSESSMENT DATE</label>
              <input type="date" name="assessmentDate" class="form-input" value="<%= assessment.assessment_date ? new Date(assessment.assessment_date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">CONTEXT / PURPOSE OF THIS ASSESSMENT</label>
            <textarea name="contextNotes" class="form-textarea" placeholder="e.g. Annual OD review before multi-year grant, preparation for leadership transition..."><%= assessment.context_notes || '' %></textarea>
          </div>
        </div>

        <!-- How it works — compact -->
        <div class="card mb-28" style="background:var(--bg-input);border-color:rgba(14,165,233,0.15)">
          <h3 class="mono" style="font-size:0.8rem;color:var(--accent-blue);letter-spacing:0.1em;margin-bottom:16px">HOW IT WORKS</h3>
          <div class="grid grid-4 gap-12">
            <% const steps = [
              ['01', 'Setup', 'Enter org details and context for this assessment.'],
              ['02', 'Assess', 'Rate 46 sub-capabilities across 13 areas on a 4-level scale.'],
              ['03', 'Plan', 'Set targets, priorities, milestones, timelines and resources.'],
              ['04', 'Report', 'Get a visual report with radar chart, Gantt timeline and action plan.'],
            ]; %>
            <% for (const [num, title, desc] of steps) { %>
            <div>
              <div class="mono" style="font-size:0.75rem;color:var(--accent);font-weight:700;margin-bottom:4px"><%= num %></div>
              <div style="font-size:0.87rem;font-weight:700;color:var(--text-secondary);margin-bottom:4px"><%= title %></div>
              <div style="font-size:0.8rem;color:var(--text-dim);line-height:1.6"><%= desc %></div>
            </div>
            <% } %>
          </div>
        </div>

        <button type="submit" class="btn btn-primary">BEGIN ASSESSMENT →</button>
      </form>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
