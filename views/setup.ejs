<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Setup — OD Anvaya</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%
  const totalSubCount = 46;
  const ratedSubCount = 0;
%>
<div class="app-shell">
  <%- include('partials/sidebar', { page: 'setup', totalSubCount, ratedSubCount }) %>
  <div class="main-content">
    <div style="max-width:680px">
      <div class="mb-40">
        <h1 style="margin-bottom:8px">Welcome to the NGO<br><span class="text-accent">OD Assessment Tool</span></h1>
        <p style="color:var(--text-muted);font-size:1rem;line-height:1.7">
          An APD initiative to support partner NGOs in building strong, inclusive organisations.
          Fill in the details below to begin a structured assessment across 13 capability areas.
        </p>
      </div>

      <form method="POST" action="/setup">
        <div class="card mb-24">
          <h2 class="mono" style="font-size:1.07rem;letter-spacing:0.08em;margin-bottom:24px;color:var(--text-secondary)">ORGANISATION DETAILS</h2>
          <div class="grid grid-2 gap-20 mb-20">
            <div class="form-group">
              <label class="form-label">ORGANISATION NAME</label>
              <input type="text" name="orgName" class="form-input" value="<%= assessment.org_name || '' %>" placeholder="e.g. Praja Foundation" required>
            </div>
            <div class="form-group">
              <label class="form-label">LEAD ASSESSOR</label>
              <input type="text" name="assessor" class="form-input" value="<%= assessment.assessor || '' %>" placeholder="e.g. Anita Sharma">
            </div>
            <div class="form-group">
              <label class="form-label">ASSESSMENT DATE</label>
              <input type="date" name="assessmentDate" class="form-input" value="<%= assessment.assessment_date ? new Date(assessment.assessment_date).toISOString().split('T')[0] : new Date().toISOString().split('T')[0] %>">
            </div>
          </div>
          <div class="form-group">
            <label class="form-label">CONTEXT / PURPOSE OF THIS ASSESSMENT</label>
            <textarea name="contextNotes" class="form-textarea" placeholder="e.g. Annual OD review before multi-year grant, preparation for leadership transition..."><%= assessment.context_notes || '' %></textarea>
          </div>
        </div>

        <div class="card mb-32" style="background:var(--bg-input);border-color:rgba(14,165,233,0.2)">
          <h3 class="mono" style="font-size:0.87rem;color:var(--accent-blue);letter-spacing:0.1em;margin-bottom:20px">HOW THIS TOOL WORKS</h3>
          <div class="grid grid-2 gap-16">
            <% const howItems = [
              ['01 ASSESS', '🎯', 'Rate each of 13 capabilities on a 4-level scale. Every level has a full description to guide your assessment.'],
              ['02 UNDERSTAND', '💡', 'Click "View Descriptions" on any sub-capability to see exactly what Level 1–4 looks like.'],
              ['03 PLAN', '📋', 'Set target levels, assign priority (Critical / High / Medium / Low), and write specific action plans.'],
              ['04 REPORT', '📊', 'Get a visual summary with radar chart, score breakdowns, and a consolidated action plan table.'],
            ]; %>
            <% for (const [title, icon, desc] of howItems) { %>
            <div class="flex gap-14" style="padding:16px;background:var(--bg-card);border-radius:var(--radius-md);border:1px solid var(--border)">
              <span style="font-size:1.47rem;flex-shrink:0"><%= icon %></span>
              <div>
                <div class="mono" style="font-size:0.73rem;color:var(--accent);font-weight:700;margin-bottom:4px"><%= title %></div>
                <div style="font-size:0.8rem;color:var(--text-muted);line-height:1.6"><%= desc %></div>
              </div>
            </div>
            <% } %>
          </div>
        </div>

        <button type="submit" class="btn btn-primary">BEGIN ASSESSMENT →</button>
      </form>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
